  .wave-mesh::before, .wave-mesh::after {
    content: '';
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    animation: waveDrift 18s ease-in-out infinite alternate;
  }
  .wave-mesh::before {
    width: 700px; height: 700px;
    top: -200px; right: -150px;
    background: radial-gradient(circle, rgba(217,119,6,.18) 0%, transparent 65%);
  }
  .wave-mesh::after {
    width: 400px; height: 400px;
    bottom: -100px; left: 0;
    background: radial-gradient(circle, rgba(14,165,233,.10) 0%, transparent 65%);
    animation-delay: -9s;
  }
  @keyframes waveDrift {
    from { transform: translate(0,0) scale(1); }
    to   { transform: translate(30px,-40px) scale(1.1); }
